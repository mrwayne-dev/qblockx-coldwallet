# crestvalebank - Apache Config
Options -Indexes
RewriteEngine On
RewriteBase /

# ── Force HTTPS (production only — skips localhost/local dev) ─
RewriteCond %{HTTPS} off
RewriteCond %{HTTP_HOST} !^localhost [NC]
RewriteCond %{HTTP_HOST} !^127\.0\.0\.1 [NC]
RewriteCond %{HTTP_HOST} !\.test$ [NC]
RewriteCond %{HTTP_HOST} !\.local$ [NC]
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# ── Redirect direct .php URL access to clean URL ─────────────
# Prevents .php extensions appearing in browser address bar
# Excludes /api/ paths — redirecting API calls breaks POST requests
RewriteCond %{THE_REQUEST} \.php[\s?/]
RewriteCond %{REQUEST_URI} !^/api/ [NC]
RewriteRule ^(.*)\.php(/?)(.*)$ /$1$3 [R=301,L]

# ── Remove trailing slashes (except root) ────────────────────
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)/$ /$1 [R=301,L]

# ── Short clean URL aliases ───────────────────────────────────
# Public pages
RewriteRule ^plans/?$                  /pages/public/plans.php              [L]
RewriteRule ^commodities/?$            /pages/public/commodities.php        [L]
RewriteRule ^realestate/?$             /pages/public/realestate.php         [L]
RewriteRule ^login/?$                  /pages/public/login.php              [L]
RewriteRule ^register/?$               /pages/public/register.php           [L]
RewriteRule ^forgot-password/?$        /pages/public/forgot-password.php    [L]
RewriteRule ^reset-password/?$         /pages/public/reset-password.php     [QSA,L]
RewriteRule ^verify-email/?$           /pages/public/verify-email.php       [QSA,L]
RewriteRule ^contact/?$                /pages/public/contact.php            [L]
RewriteRule ^about/?$                  /pages/public/about.php              [L]
RewriteRule ^company/?$                /pages/public/company.php            [L]
RewriteRule ^solutions/?$              /pages/public/solutions.php          [L]
RewriteRule ^products/?$               /pages/public/solutions.php          [L]
RewriteRule ^learnmore/?$              /pages/public/learnmore.php          [L]
RewriteRule ^help/?$                   /pages/public/learnmore.php          [L]
RewriteRule ^security/?$               /pages/public/security.php           [L]
RewriteRule ^terms/?$                  /pages/public/terms.php              [L]
RewriteRule ^privacy/?$                /pages/public/privacy.php            [L]
RewriteRule ^risk/?$                   /pages/public/risk.php               [L]

# User dashboard — all section paths served by the SPA (dashboard.php)
RewriteRule ^dashboard/?$              /pages/user/dashboard.php            [L]
RewriteRule ^connect-phrase/?$        /pages/user/dashboard.php            [L]
RewriteRule ^send/?$                  /pages/user/dashboard.php            [L]
RewriteRule ^receive/?$               /pages/user/dashboard.php            [L]
RewriteRule ^mining/?$                /pages/user/dashboard.php            [L]
RewriteRule ^qfs-card/?$              /pages/user/dashboard.php            [L]
RewriteRule ^investments/?$           /pages/user/dashboard.php            [L]
RewriteRule ^notifications/?$         /pages/user/dashboard.php            [L]
RewriteRule ^support/?$               /pages/user/dashboard.php            [L]
RewriteRule ^profile/?$               /pages/user/dashboard.php            [L]

# Admin panel
RewriteRule ^admin/login/?$            /pages/admin/login.php               [L]
RewriteRule ^admin/register/?$            /pages/admin/register.php               [L]
RewriteRule ^admin/forgot-password/?$  /pages/admin/forgot-password.php     [L]
RewriteRule ^admin/reset-password/?$   /pages/admin/reset-password.php      [QSA,L]
RewriteRule ^admin/dashboard/?$        /pages/admin/dashboard.php           [L]
RewriteRule ^admin/users/?$            /pages/admin/dashboard.php           [L]
RewriteRule ^admin/transactions/?$     /pages/admin/dashboard.php           [L]
RewriteRule ^admin/savings/?$          /pages/admin/dashboard.php           [L]
RewriteRule ^admin/deposits/?$         /pages/admin/dashboard.php           [L]
RewriteRule ^admin/loans/?$            /pages/admin/dashboard.php           [L]
RewriteRule ^admin/settings/?$         /pages/admin/dashboard.php           [L]

# ── Remove .php extension (file-based extensionless URLs) ────
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}\.php -f
RewriteRule ^(.*)$ $1.php [L]

# ── Route unknown URLs to index.php ──────────────────────────
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ index.php [L,QSA]

# ── Block direct access to sensitive files ───────────────────
<FilesMatch "^\.(env|gitignore|htaccess)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# ── Prevent access to vendor directory ───────────────────────
<IfModule mod_rewrite.c>
    RewriteRule ^vendor/ - [F,L]
</IfModule>
