-    if (attempt >= _paymentPollMax) return;
-
-    try {
-      var r = await apiFetch('/api/payments/now-payment-status.php', {
-        method: 'POST',
-        body: JSON.stringify({ invoice_id: invoiceId })
-      });
-
-      if (r.success && r.status === 'completed') {
